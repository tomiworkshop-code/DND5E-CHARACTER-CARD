      "subclass_level": 3,
      "subclasses": [
        {
          "name_zh": "狂戰士之道",
          "name_en": "Path of the Berserker",
          "desc_zh": "狂暴時可進入『狂亂』獲得額外一次攻擊，代價是回合後陷入力竭。純粹的暴力輸出流。"
        },
        {
          "name_zh": "圖騰武者之道",
          "name_en": "Path of the Totem Warrior",
          "desc_zh": "選擇靈魂圖騰（熊／鷹／狼等）取得對應增益，如熊圖騰在狂暴時抗除精神外所有傷害，適合坦克。"
        }
      ]
    },
    {
      "name_zh": "吟遊詩人",
      "name_en": "Bard",
      "hit_dice": "d8",
      "skills_choices": [
        "任何技能"
      ],
      "subclass_label": "詩人學院",
      "subclass_level": 3,
      "subclasses": [
        {
          "name_zh": "知識學院",
          "name_en": "College of Lore",
          "desc_zh": "再獲三項技能熟練與『銳語切磋』（以鼓舞骰扣減敵人攻擊／檢定／傷害），6級可借用他職法術，博學多聞型。"
        },
        {
          "name_zh": "勇氣學院",
          "name_en": "College of Valor",
          "desc_zh": "獲得中甲、盾牌與軍用武器熟練；鼓舞骰可加武器傷害或AC，6級可額外攻擊，前線戰吟型。"
        }
      ]
    },
    {
      "name_zh": "牧師",
      "name_en": "Cleric",
      "hit_dice": "d8",
      "skills_choices": [
        "歷史",
        "洞悉",
        "醫藥",
        "遊說",
        "宗教"
      ],
      "subclass_label": "神聖領域",
      "subclass_level": 1,
      "subclasses": [
        {
          "name_zh": "知識領域",
          "name_en": "Knowledge Domain",
          "desc_zh": "通曉語言與雙倍技能熟練，善用預言與探知，博學導向。"
        },
        {
          "name_zh": "生命領域",
          "name_en": "Life Domain",
          "desc_zh": "重甲熟練，治療法術額外回復生命，最強白值奶媽。"
        },
        {
          "name_zh": "光明領域",
          "name_en": "Light Domain",
          "desc_zh": "焰化爆發護身，擅長塑能範圍傷害與驅散黑暗。"
        },
        {
          "name_zh": "自然領域",
          "name_en": "Nature Domain",
          "desc_zh": "重甲與德魯伊系法術，可魅惑動植物、招喚自然之力。"
        },
        {
          "name_zh": "風暴領域",
          "name_en": "Tempest Domain",
          "desc_zh": "重甲熟練，受擊可電擊反擊，雷電傷害擲最大值。"
        },
        {
          "name_zh": "詭術領域",
          "name_en": "Trickery Domain",
          "desc_zh": "賜予盟友潛行祝福，可製造分身幻影，欺敵滲透導向。"
        },
        {
          "name_zh": "戰爭領域",
          "name_en": "War Domain",
          "desc_zh": "重甲與軍用武器熟練，可額外附贈神力加值攻擊，戰鬥牧師。"
        }
      ]
    },
